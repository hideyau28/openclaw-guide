41:["$","p",null,{"children":["支持。用 ",["$","code",null,{"className":"rounded bg-red-50 px-1.5 py-0.5 text-sm font-mono text-red-700","children":"email"}]," Skill（IMAP 版本）代替 ",["$","code",null,{"className":"rounded bg-red-50 px-1.5 py-0.5 text-sm font-mono text-red-700","children":"gmail"}]," Skill，Outlook 嘅 IMAP 設定係 ",["$","code",null,{"className":"rounded bg-red-50 px-1.5 py-0.5 text-sm font-mono text-red-700","children":"outlook.office365.com:993"}],"。需要喺 Microsoft 帳號設定開啟 IMAP 存取，同生成 App Password。"]}]
42:["$","p",null,{"children":["$","strong",null,{"children":"Q：可唔可以自動回覆 email？"}]}]
43:["$","p",null,{"children":["技術上可以，但",["$","strong",null,{"children":"極度唔建議"}],"。AI 發出去嘅 email 係真實嘅，發咗就發咗，唔能撤回。AI 誤解一封 email 然後自動回覆一個不當內容，後果可以好嚴重。如果你真係想試，建議只喺測試帳號用，而且加入強制確認步驟（Agent 草擬後先問你批准）。"]}]
44:["$","p",null,{"children":["$","strong",null,{"children":"Q：Email 內容會唔會上傳去雲端？"}]}]
45:["$","p",null,{"children":"視乎你用嘅 LLM provider。用 Anthropic / OpenAI = email 內容發送去佢哋嘅 server（受各自嘅私隱政策管理）。用本地 Ollama = email 完全唔離開你嘅電腦。如果隱私係你嘅首要考量，用 Ollama 係唯一完全本地嘅方案，但模型能力會弱一些。"}]
46:["$","p",null,{"children":["$","strong",null,{"children":"Q：可唔可以只處理某幾個寄件人嘅 email？"}]}]
47:["$","p",null,{"children":"可以，喺 prompt template 加入過濾條件："}]
48:["$","figure",null,{"data-rehype-pretty-code-figure":"","children":["$","pre",null,{"className":"my-4 overflow-x-auto rounded-xl bg-[#0F172A] p-5 text-sm","style":{"backgroundColor":"#24292e","color":"#e1e4e8"},"tabIndex":"0","data-language":"markdown","data-theme":"github-dark","children":["$","code",null,{"className":"rounded bg-red-50 px-1.5 py-0.5 text-sm font-mono text-red-700","data-language":"markdown","data-theme":"github-dark","style":{"display":"grid"},"children":[["$","span",null,{"data-line":"","children":["$","span",null,{"style":{"color":"#E1E4E8"},"children":"只處理以下寄件人嘅 email："}]}],"\n",["$","span",null,{"data-line":"","children":[["$","span",null,{"style":{"color":"#FFAB70"},"children":"-"}],["$","span",null,{"style":{"color":"#E1E4E8"},"children":" client@example.com"}]]}],"\n",["$","span",null,{"data-line":"","children":[["$","span",null,{"style":{"color":"#FFAB70"},"children":"-"}],["$","span",null,{"style":{"color":"#E1E4E8"},"children":" boss@company.com"}]]}],"\n",["$","span",null,{"data-line":"","children":["$","span",null,{"style":{"color":"#E1E4E8"},"children":"忽略所有行銷 email（Unsubscribe 連結嘅一律略過）。"}]}]]}]}]}]
