{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/security/layout,_N_T_/security/[slug]/layout,_N_T_/security/[slug]/page,_N_T_/security/essential-guide"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/security/$d$slug/__PAGE__",
    "/security/$d$slug",
    "/security",
    "/_index",
    "/_head"
  ]
}