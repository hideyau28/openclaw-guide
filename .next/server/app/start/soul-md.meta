{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/start/layout,_N_T_/start/[slug]/layout,_N_T_/start/[slug]/page,_N_T_/start/soul-md"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/start/$d$slug/__PAGE__",
    "/start/$d$slug",
    "/start",
    "/_index",
    "/_head"
  ]
}