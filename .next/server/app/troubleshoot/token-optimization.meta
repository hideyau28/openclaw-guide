{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/troubleshoot/layout,_N_T_/troubleshoot/[slug]/layout,_N_T_/troubleshoot/[slug]/page,_N_T_/troubleshoot/token-optimization"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/troubleshoot/$d$slug/__PAGE__",
    "/troubleshoot/$d$slug",
    "/troubleshoot",
    "/_index",
    "/_head"
  ]
}